<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Paneli</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
            body { overflow-x: hidden; background-color: #f4f6f9; }
            #wrapper { display: flex; }
            #sidebar-wrapper { min-height: 100vh; width: 250px; background: #212529; color: #fff; transition: margin .25s ease-out; }
            #sidebar-wrapper .sidebar-heading { padding: 1.5rem; font-size: 1.25rem; font-weight: bold; border-bottom: 1px solid #343a40; text-align: center; }
            #page-content-wrapper { flex-grow: 1; min-width: 0; }
            .list-group-item { background: transparent; color: #adb5bd; border: none; padding: 1rem 1.5rem; transition: all 0.3s; }
            .list-group-item:hover { background: #343a40; color: #fff; padding-left: 2rem; }
            .list-group-item.active { background: #0d6efd; color: #fff; border-radius: 8px; margin: 0 10px; padding-left: 1.5rem; }
        
            @@media (max-width: 768px) {
                #sidebar-wrapper { margin-left: -250px; }
                body.sb-sidenav-toggled #sidebar-wrapper { margin-left: 0; }
            }
            /* Masaüstünde menüyü gizleme kodu (BUNU EKLE) */
body.sb-sidenav-toggled #sidebar-wrapper { margin-left: -250px; }

/* Mobilde yan menüyü gizleme ayarları (Bu zaten vardı) */
@@media (max-width: 768px) {
    #sidebar-wrapper { margin-left: -250px; }
    body.sb-sidenav-toggled #sidebar-wrapper { margin-left: 0; }
}
    </style>

    <script>
        var token = localStorage.getItem("token");
        
        if (!token) {
            window.location.href = "/Home/Login";
        } else {
            try {
                var payload = JSON.parse(atob(token.split('.')[1]));
                var role = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
                
                if (role !== "Admin") {
                    alert("Güvenlik: Bu sayfaya sadece Yöneticiler (Admin) girebilir!");
                    localStorage.removeItem("token"); 
                    window.location.href = "/Home/Login";
                }
            } catch (e) {
                localStorage.removeItem("token");
                window.location.href = "/Home/Login";
            }
        }
    </script>
</head>

<body>
    <div id="wrapper">
        <div id="sidebar-wrapper">
            <div class="sidebar-heading">
                <i class="fa-solid fa-store text-warning me-2"></i> Dükkan Yönetim
            </div>
            <div class="list-group list-group-flush mt-3">
            @{
                // Şu an hangi sayfada olduğumuzu yakalıyoruz
                var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
            }
            <a href="/Home/Products" class="list-group-item list-group-item-action @(currentAction == "Products" ? "active" : "")">
                <i class="fa-solid fa-box-open me-2"></i> Ürün Yönetimi
            </a>
            <a href="/Home/Index" class="list-group-item list-group-item-action @(currentAction == "Index" ? "active" : "")">
                <i class="fa-solid fa-tags me-2"></i> Kategoriler
            </a>
            <a href="#" id="btnLogout" class="list-group-item list-group-item-action text-danger mt-5">
                <i class="fa-solid fa-sign-out-alt me-2"></i> Çıkış Yap
            </a>
        </div>
        </div>

        <div id="page-content-wrapper">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm py-3">
                <div class="container-fluid">
                    <button class="btn btn-outline-secondary btn-sm" id="sidebarToggle">
                        <i class="fa-solid fa-bars"></i> Menü
                    </button>
                    <div class="ms-auto d-flex align-items-center">
                        <i class="fa-solid fa-circle-user fs-4 text-secondary me-2"></i>
                        <span class="fw-bold">Hoş geldin, Admin</span>
                    </div>
                </div>
            </nav>
            
            <div class="container-fluid p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Menü Aç/Kapat
        document.getElementById('sidebarToggle').addEventListener('click', function(e) {
            e.preventDefault();
            document.body.classList.toggle('sb-sidenav-toggled');
        });

        // Çıkış Yap
        document.getElementById('btnLogout').addEventListener('click', function(e) {
            e.preventDefault();
            if(confirm("Çıkış yapmak istediğinize emin misiniz?")) {
                localStorage.removeItem("token");
                window.location.href = "/Home/Login";
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>